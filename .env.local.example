# ──────────────────────────────────────────────────────────────
# MediSmile Group — Environment Variables
# Copy this file to `.env.local` and fill in the real values.
# NEVER commit `.env.local`. Public (NEXT_PUBLIC_*) vars are exposed
# to the browser; everything else stays server-side only.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
# Server-only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ── Anthropic (AI Agent) ──────────────────────────────────────
# Server-only.
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── WhatsApp (Evolution API) ──────────────────────────────────
# Server-only.
EVOLUTION_API_URL=https://api.medismile.com
EVOLUTION_API_KEY=xxx
EVOLUTION_INSTANCE=medismile
# Commercial team number that receives qualified-lead notifications.
WHATSAPP_COMMERCIAL_NUMBER=16893103396

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# ── Analytics / Monitoring ────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-xxx
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
